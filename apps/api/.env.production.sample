# =============================================
# Backend API — Production Environment Variables
# Thiết lập các biến này trên Dashboard Render.com
# =============================================

NODE_ENV=production
PORT=10000

# ---- PostgreSQL (Lấy từ Neon.tech) ----
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require"

# ---- MongoDB (Lấy từ MongoDB Atlas) ----
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/dbname"

# ---- Redis (Lấy từ Upstash) ----
REDIS_URL="rediss://default:password@endpoint.upstash.io:6379"

# ---- JWT (Hãy tạo chuỗi ngẫu nhiên dài ít nhất 32 ký tự) ----
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_here
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Supabase (Audio + Images) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Meilisearch ----
MEILI_HOST=https://your-meilisearch-endpoint.com
MEILI_MASTER_KEY=your_meilisearch_master_key

# ---- Email (Gửi mail thông báo) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# ---- VNPAY (Thanh toán) ----
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://ringbeatmusic-backend.onrender.com/api/v1/subscription/vnpay-return

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://ringbeatmusic-backend.onrender.com/api/v1/auth/google/callback

# ---- Cloudinary (Avatar, Thumbnail) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Frontend URL (CORS) ----
FRONTEND_URL=https://ringbeatmusic.onrender.com
